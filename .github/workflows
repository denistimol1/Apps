name: Build APK

on:
  push:
    branches: [ main ]
  workflow_dispatch:

jobs:
  build:
    runs-on: ubuntu-latest

    steps:
      - name: Checkout code
        uses: actions/checkout@v4

      - name: Set up JDK 17
        uses: actions/setup-java@v4
        with:
          java-version: '17'
          distribution: 'temurin'

      - name: Set up Android SDK
        uses: android-actions/setup-android@v3

      - name: Install Gradle 8.7
        uses: gradle/actions/setup-gradle@v3
        with:
          gradle-version: '8.7'

      - name: Find project root and generate Gradle Wrapper
        run: |
          find . -name "settings.gradle.kts" -o -name "settings.gradle" | head -5
          PROJECT_DIR=$(find . -name "settings.gradle.kts" | head -1 | xargs dirname)
          echo "PROJECT_DIR=$PROJECT_DIR" >> $GITHUB_ENV
          cd "$PROJECT_DIR"
          gradle wrapper --gradle-version 8.7

      - name: Grant execute permission for gradlew
        run: chmod +x ${{ env.PROJECT_DIR }}/gradlew

      - name: Inject Groq API Key
        run: |
          sed -i 's/YOUR_GROQ_API_KEY/${{ secrets.GROQ_API_KEY }}/g' \
            ${{ env.PROJECT_DIR }}/app/src/main/java/com/vkusnoplan/app/network/AnthropicClient.kt

      - name: Build Debug APK
        working-directory: ${{ env.PROJECT_DIR }}
        run: ./gradlew assembleDebug --stacktrace

      - name: Upload APK
        uses: actions/upload-artifact@v4
        with:
          name: VkusnoPlan-debug
          path: ${{ env.PROJECT_DIR }}/app/build/outputs/apk/debug/app-debug.apk
          retention-days: 30
